# ══════════════════════════════════════════════════════════
# VaultMCP Backend — Environment Variables
# ══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All keys are required for full functionality.
# The app runs without them, but features will be limited.
# ══════════════════════════════════════════════════════════

# ─── Hugging Face ───────────────────────────────────────
# Used for: Whisper transcription + Mistral AI structuring
# Get your free token: https://huggingface.co/settings/tokens
# Requires: "Read" access (free tier works)
HF_TOKEN=

# ─── Google Drive OAuth2 ────────────────────────────────
# Used for: Saving vault.md to user's Google Drive
# Setup:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Add redirect URI: http://localhost:8000/auth/callback
#   4. Enable the Google Drive API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Web Search (pick one or both) ──────────────────────
# Used for: Finding official links for extracted tools/concepts
#
# Tavily (primary) — 1000 free searches/month
# Sign up: https://tavily.com
TAVILY_API_KEY=

# Serper (fallback) — 2500 free searches
# Sign up: https://serper.dev
SERPER_API_KEY=

# Which provider to try first: "tavily" or "serper"
SEARCH_PROVIDER=tavily

# ─── Server Config ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
